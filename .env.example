# Database Configuration (Docker context)
DATABASE_URL=postgresql://admin:your_password@db:5432/tattoo_studio
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=tattoo_studio

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_APP=app.py
FLASK_SECRET_KEY=your-secret-key-here
HOST=0.0.0.0
PORT=5000

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTHLIB_INSECURE_TRANSPORT=1
OAUTHLIB_RELAX_TOKEN_SCOPE=1

# Jotform Integration
JOTFORM_API_KEY=your-jotform-api-key
JOTFORM_FORM_ID=your-jotform-form-id

# Optional Google Calendar Settings
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
GOOGLE_API_KEY=your-google-api-key
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
